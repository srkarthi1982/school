---
import { actions } from "astro:actions";
import { AvButton, AvCard, AvConfirmDialog, AvContainer, AvIcon, AvInput, AvSelect } from "@ansiversa/components";
import AppShell from "../../layouts/AppShell.astro";
import SettingsDrawer from "../../components/drawers/SettingsDrawer.astro";
import { APP_META } from "../../app.meta";

const title = `${APP_META.name} App`;
const description = "Protected School Ansiversa backend workspace.";

const emptyState = {
  school: null,
  classes: [],
  sections: [],
  subjects: [],
  students: [],
  teachers: [],
};

const workspaceResult = await Astro.callAction(actions.schoolFoundation.getFoundationWorkspace, {});
const initialState = workspaceResult.error ? emptyState : (workspaceResult.data ?? emptyState);
const initialStateJson = JSON.stringify(initialState).replace(/</g, "\\u003c");

const tabs = [
  { key: "classes", label: "Classes" },
  { key: "sections", label: "Sections" },
  { key: "subjects", label: "Subjects" },
  { key: "students", label: "Students" },
  { key: "teachers", label: "Teachers" },
  { key: "attendance", label: "Attendance" },
];
---

<AppShell title={title} description={description}>
  <script is:inline set:html={`window.__SCHOOL_FOUNDATION_INITIAL__ = ${initialStateJson};`}></script>

  <section
    class="av-section school-foundation"
    x-data
    x-init="$store.schoolFoundation.init(window.__SCHOOL_FOUNDATION_INITIAL__)"
  >
    <AvContainer>
      <div class="av-auth-stack-lg">
        <div class="school-foundation__header">
          <div class="av-auth-stack-xs">
            <p class="av-kicker">School Ansiversa</p>
            <h1 class="av-section-title">School backend foundation</h1>
            <p class="av-text-soft">
              Create the school organization first, then add the basic academic master records.
              Students and teachers here are internal school records only.
            </p>
          </div>
          <div class="av-row-wrap">
            <AvButton href="/">Back to landing</AvButton>
            <AvButton href="/signout" variant="ghost">Sign out</AvButton>
          </div>
        </div>

        <template x-if="$store.schoolFoundation.error">
          <div class="school-foundation__notice school-foundation__notice--error" x-text="$store.schoolFoundation.error"></div>
        </template>
        <template x-if="$store.schoolFoundation.success">
          <div class="school-foundation__notice school-foundation__notice--success" x-text="$store.schoolFoundation.success"></div>
        </template>

        <AvCard className="av-auth-card">
          <div class="school-foundation__card-grid">
            <div class="av-auth-stack-xs">
              <p class="av-kicker">Setup</p>
              <h2 class="av-card-heading">School organization</h2>
              <p class="av-text-soft">
                This record belongs to the logged-in Ansiversa owner. Other foundation data is
                scoped to this school.
              </p>
            </div>

            <div class="av-auth-stack-sm">
              <template x-if="!$store.schoolFoundation.school">
                <div class="school-foundation__empty">
                  No school organization exists yet. Create the school first to unlock foundation records.
                </div>
              </template>

              <template x-if="$store.schoolFoundation.school">
                <div class="school-foundation__summary-grid">
                  <div class="school-foundation__summary-item">
                    <span>School name</span>
                    <strong x-text="$store.schoolFoundation.school?.name || '-'"></strong>
                  </div>
                  <div class="school-foundation__summary-item">
                    <span>Slug</span>
                    <strong x-text="$store.schoolFoundation.school?.slug || '-'"></strong>
                  </div>
                  <div class="school-foundation__summary-item">
                    <span>Country</span>
                    <strong x-text="$store.schoolFoundation.school?.country || '-'"></strong>
                  </div>
                  <div class="school-foundation__summary-item">
                    <span>Timezone</span>
                    <strong x-text="$store.schoolFoundation.school?.timezone || '-'"></strong>
                  </div>
                  <div class="school-foundation__summary-item">
                    <span>Currency</span>
                    <strong x-text="$store.schoolFoundation.school?.currency || '-'"></strong>
                  </div>
                </div>
              </template>

              <div class="av-row-wrap">
                <AvButton
                  type="button"
                  @click.prevent="$store.schoolFoundation.openSchoolDrawer(); $store.appDrawer.open('settings')"
                >
                  <span x-text="$store.schoolFoundation.hasSchool ? 'Edit school' : 'Create school'"></span>
                </AvButton>
              </div>
            </div>
          </div>
        </AvCard>

        <template x-if="$store.appDrawer.activeDrawer === 'settings' && !$store.schoolFoundation.hasSchool">
          <SettingsDrawer
            title="Create school"
            description="Create the owner-scoped school organization before adding foundation records."
          >
            <form id="school-organization-drawer-form-create" class="av-auth-stack-md" @submit.prevent="$store.schoolFoundation.saveSchool()">
              <AvInput label="School name" name="drawer-school-name-create" x-model="$store.schoolFoundation.schoolForm.name" required />
              <AvInput label="Slug" name="drawer-school-slug-create" x-model="$store.schoolFoundation.schoolForm.slug" hint="Optional. Generated from the name if blank." />
              <AvInput label="Country" name="drawer-school-country-create" x-model="$store.schoolFoundation.schoolForm.country" required />
              <AvInput label="Timezone" name="drawer-school-timezone-create" x-model="$store.schoolFoundation.schoolForm.timezone" required />
              <AvInput label="Currency" name="drawer-school-currency-create" x-model="$store.schoolFoundation.schoolForm.currency" required />
            </form>

            <template slot="notice" x-if="$store.schoolFoundation.schoolDrawerError">
              <p class="school-foundation__drawer-error" x-text="$store.schoolFoundation.schoolDrawerError"></p>
            </template>

            <div slot="actions" class="av-row-wrap av-drawer-footer-actions">
              <AvButton type="button" variant="ghost" @click.prevent="$store.appDrawer.close()">Cancel</AvButton>
              <AvButton
                type="submit"
                form="school-organization-drawer-form-create"
                :disabled="$store.schoolFoundation.loading"
              >
                <span x-text="$store.schoolFoundation.loading ? 'Saving...' : 'Save school'"></span>
              </AvButton>
            </div>
          </SettingsDrawer>
        </template>

        <template x-if="$store.appDrawer.activeDrawer === 'settings' && $store.schoolFoundation.hasSchool">
          <SettingsDrawer
            title="Edit school"
            description="Update the owner-scoped school organization details."
          >
            <form id="school-organization-drawer-form-edit" class="av-auth-stack-md" @submit.prevent="$store.schoolFoundation.saveSchool()">
              <AvInput label="School name" name="drawer-school-name-edit" x-model="$store.schoolFoundation.schoolForm.name" required />
              <AvInput label="Slug" name="drawer-school-slug-edit" x-model="$store.schoolFoundation.schoolForm.slug" hint="Optional. Generated from the name if blank." />
              <AvInput label="Country" name="drawer-school-country-edit" x-model="$store.schoolFoundation.schoolForm.country" required />
              <AvInput label="Timezone" name="drawer-school-timezone-edit" x-model="$store.schoolFoundation.schoolForm.timezone" required />
              <AvInput label="Currency" name="drawer-school-currency-edit" x-model="$store.schoolFoundation.schoolForm.currency" required />
            </form>

            <template slot="notice" x-if="$store.schoolFoundation.schoolDrawerError">
              <p class="school-foundation__drawer-error" x-text="$store.schoolFoundation.schoolDrawerError"></p>
            </template>

            <div slot="actions" class="av-row-wrap av-drawer-footer-actions">
              <AvButton type="button" variant="ghost" @click.prevent="$store.appDrawer.close()">Cancel</AvButton>
              <AvButton
                type="submit"
                form="school-organization-drawer-form-edit"
                :disabled="$store.schoolFoundation.loading"
              >
                <span x-text="$store.schoolFoundation.loading ? 'Saving...' : 'Save school'"></span>
              </AvButton>
            </div>
          </SettingsDrawer>
        </template>

        <template x-if="$store.appDrawer.activeDrawer === 'class'">
          <SettingsDrawer
            title="Add class"
            titleExpression="$store.schoolFoundation.foundationFormMode === 'edit' ? 'Edit class' : 'Add class'"
            description="Create or update a class level for this school."
          >
            <form id="school-class-drawer-form" class="av-auth-stack-md" @submit.prevent="$store.schoolFoundation.saveClass()">
              <AvInput label="Class name" name="drawer-class-name" x-model="$store.schoolFoundation.classForm.name" required />
              <AvInput label="Sort order" name="drawer-class-sort" type="number" x-model.number="$store.schoolFoundation.classForm.sortOrder" />
            </form>

            <template slot="notice" x-if="$store.schoolFoundation.foundationDrawerError">
              <p class="school-foundation__drawer-error" x-text="$store.schoolFoundation.foundationDrawerError"></p>
            </template>

            <div slot="actions" class="av-row-wrap av-drawer-footer-actions">
              <AvButton type="button" variant="ghost" @click.prevent="$store.appDrawer.close()">Cancel</AvButton>
              <AvButton type="submit" form="school-class-drawer-form" :disabled="$store.schoolFoundation.loading">
                <span x-text="$store.schoolFoundation.loading ? 'Saving...' : 'Save class'"></span>
              </AvButton>
            </div>
          </SettingsDrawer>
        </template>

        <template x-if="$store.appDrawer.activeDrawer === 'section'">
          <SettingsDrawer
            title="Add section"
            titleExpression="$store.schoolFoundation.foundationFormMode === 'edit' ? 'Edit section' : 'Add section'"
            description="Create or update a section under an existing class."
          >
            <form id="school-section-drawer-form" class="av-auth-stack-md" @submit.prevent="$store.schoolFoundation.saveSection()">
              <label class="av-field">
                <span class="av-field__label">Class *</span>
                <select
                  class="av-input"
                  x-model="$store.schoolFoundation.sectionForm.classId"
                  x-effect="$nextTick(() => { $el.value = $store.schoolFoundation.sectionForm.classId })"
                  required
                >
                  <option value="">Select class</option>
                  <template x-for="item in $store.schoolFoundation.classes" :key="item.id">
                    <option :value="String(item.id)" x-text="item.name"></option>
                  </template>
                </select>
              </label>
              <AvInput label="Section name" name="drawer-section-name" x-model="$store.schoolFoundation.sectionForm.name" required />
              <AvInput label="Sort order" name="drawer-section-sort" type="number" x-model.number="$store.schoolFoundation.sectionForm.sortOrder" />
            </form>

            <template slot="notice" x-if="$store.schoolFoundation.foundationDrawerError">
              <p class="school-foundation__drawer-error" x-text="$store.schoolFoundation.foundationDrawerError"></p>
            </template>

            <div slot="actions" class="av-row-wrap av-drawer-footer-actions">
              <AvButton type="button" variant="ghost" @click.prevent="$store.appDrawer.close()">Cancel</AvButton>
              <AvButton type="submit" form="school-section-drawer-form" :disabled="$store.schoolFoundation.loading">
                <span x-text="$store.schoolFoundation.loading ? 'Saving...' : 'Save section'"></span>
              </AvButton>
            </div>
          </SettingsDrawer>
        </template>

        <template x-if="$store.appDrawer.activeDrawer === 'subject'">
          <SettingsDrawer
            title="Add subject"
            titleExpression="$store.schoolFoundation.foundationFormMode === 'edit' ? 'Edit subject' : 'Add subject'"
            description="Create or update a subject in the school catalog."
          >
            <form id="school-subject-drawer-form" class="av-auth-stack-md" @submit.prevent="$store.schoolFoundation.saveSubject()">
              <AvInput label="Subject name" name="drawer-subject-name" x-model="$store.schoolFoundation.subjectForm.name" required />
              <AvInput label="Code" name="drawer-subject-code" x-model="$store.schoolFoundation.subjectForm.code" />
            </form>

            <template slot="notice" x-if="$store.schoolFoundation.foundationDrawerError">
              <p class="school-foundation__drawer-error" x-text="$store.schoolFoundation.foundationDrawerError"></p>
            </template>

            <div slot="actions" class="av-row-wrap av-drawer-footer-actions">
              <AvButton type="button" variant="ghost" @click.prevent="$store.appDrawer.close()">Cancel</AvButton>
              <AvButton type="submit" form="school-subject-drawer-form" :disabled="$store.schoolFoundation.loading">
                <span x-text="$store.schoolFoundation.loading ? 'Saving...' : 'Save subject'"></span>
              </AvButton>
            </div>
          </SettingsDrawer>
        </template>

        <template x-if="$store.appDrawer.activeDrawer === 'student'">
          <SettingsDrawer
            title="Add student"
            titleExpression="$store.schoolFoundation.foundationFormMode === 'edit' ? 'Edit student' : 'Add student'"
            description="Create or update an internal student record for this school."
          >
            <form id="school-student-drawer-form" class="av-auth-stack-md" @submit.prevent="$store.schoolFoundation.saveStudent()">
              <AvInput label="Admission number" name="drawer-student-admission" x-model="$store.schoolFoundation.studentForm.admissionNumber" required />
              <AvInput label="Roll number" name="drawer-student-roll" x-model="$store.schoolFoundation.studentForm.rollNumber" />
              <AvInput label="Full name" name="drawer-student-name" x-model="$store.schoolFoundation.studentForm.fullName" required />
              <AvInput label="Date of birth" name="drawer-student-dob" type="date" x-model="$store.schoolFoundation.studentForm.dateOfBirth" />
              <label class="av-field">
                <span class="av-field__label">Class *</span>
                <select
                  class="av-input"
                  x-model="$store.schoolFoundation.studentForm.classId"
                  x-effect="$nextTick(() => { $el.value = $store.schoolFoundation.studentForm.classId })"
                  @change="$store.schoolFoundation.setStudentClass($event.target.value)"
                  required
                >
                  <option value="">Select class</option>
                  <template x-for="item in $store.schoolFoundation.classes" :key="item.id">
                    <option :value="String(item.id)" x-text="item.name"></option>
                  </template>
                </select>
              </label>
              <label class="av-field">
                <span class="av-field__label">Section *</span>
                <select
                  class="av-input"
                  x-model="$store.schoolFoundation.studentForm.sectionId"
                  x-effect="$nextTick(() => { $el.value = $store.schoolFoundation.studentForm.sectionId })"
                  required
                >
                  <option value="">Select section</option>
                  <template x-for="item in $store.schoolFoundation.sectionsForClass($store.schoolFoundation.studentForm.classId)" :key="item.id">
                    <option :value="String(item.id)" x-text="item.name"></option>
                  </template>
                </select>
              </label>
              <AvSelect label="Gender" name="drawer-student-gender" x-model="$store.schoolFoundation.studentForm.gender">
                <option value="unspecified">Unspecified</option>
                <option value="female">Female</option>
                <option value="male">Male</option>
                <option value="other">Other</option>
              </AvSelect>
              <AvSelect label="Status" name="drawer-student-status" x-model="$store.schoolFoundation.studentForm.status">
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
              </AvSelect>
              <AvInput label="Guardian name" name="drawer-guardian-name" x-model="$store.schoolFoundation.studentForm.guardianName" />
              <AvInput label="Guardian phone" name="drawer-guardian-phone" x-model="$store.schoolFoundation.studentForm.guardianPhone" />
            </form>

            <template slot="notice" x-if="$store.schoolFoundation.foundationDrawerError">
              <p class="school-foundation__drawer-error" x-text="$store.schoolFoundation.foundationDrawerError"></p>
            </template>

            <div slot="actions" class="av-row-wrap av-drawer-footer-actions">
              <AvButton type="button" variant="ghost" @click.prevent="$store.appDrawer.close()">Cancel</AvButton>
              <AvButton type="submit" form="school-student-drawer-form" :disabled="$store.schoolFoundation.loading">
                <span x-text="$store.schoolFoundation.loading ? 'Saving...' : 'Save student'"></span>
              </AvButton>
            </div>
          </SettingsDrawer>
        </template>

        <template x-if="$store.appDrawer.activeDrawer === 'teacher'">
          <SettingsDrawer
            title="Add teacher"
            titleExpression="$store.schoolFoundation.foundationFormMode === 'edit' ? 'Edit teacher' : 'Add teacher'"
            description="Create or update an internal teacher record for this school."
          >
            <form id="school-teacher-drawer-form" class="av-auth-stack-md" @submit.prevent="$store.schoolFoundation.saveTeacher()">
              <AvInput label="Employee number" name="drawer-teacher-employee" x-model="$store.schoolFoundation.teacherForm.employeeNumber" required />
              <AvInput label="Full name" name="drawer-teacher-name" x-model="$store.schoolFoundation.teacherForm.fullName" required />
              <AvInput label="Phone" name="drawer-teacher-phone" x-model="$store.schoolFoundation.teacherForm.phone" />
              <AvInput label="Email" name="drawer-teacher-email" type="email" x-model="$store.schoolFoundation.teacherForm.email" />
              <label class="av-field">
                <span class="av-field__label">Primary subject</span>
                <select
                  class="av-input"
                  x-model="$store.schoolFoundation.teacherForm.primarySubjectId"
                  x-effect="$nextTick(() => { $el.value = $store.schoolFoundation.teacherForm.primarySubjectId })"
                >
                  <option value="">Select subject</option>
                  <template x-for="item in $store.schoolFoundation.subjects" :key="item.id">
                    <option :value="String(item.id)" x-text="item.name"></option>
                  </template>
                </select>
              </label>
              <AvSelect label="Status" name="drawer-teacher-status" x-model="$store.schoolFoundation.teacherForm.status">
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
              </AvSelect>
            </form>

            <template slot="notice" x-if="$store.schoolFoundation.foundationDrawerError">
              <p class="school-foundation__drawer-error" x-text="$store.schoolFoundation.foundationDrawerError"></p>
            </template>

            <div slot="actions" class="av-row-wrap av-drawer-footer-actions">
              <AvButton type="button" variant="ghost" @click.prevent="$store.appDrawer.close()">Cancel</AvButton>
              <AvButton type="submit" form="school-teacher-drawer-form" :disabled="$store.schoolFoundation.loading">
                <span x-text="$store.schoolFoundation.loading ? 'Saving...' : 'Save teacher'"></span>
              </AvButton>
            </div>
          </SettingsDrawer>
        </template>

        <AvCard variant="soft" className="school-foundation__workspace">
          <div class="school-foundation__tabs" role="tablist" aria-label="School foundation sections">
            {tabs.map((tab) => (
              <button
                type="button"
                class="school-foundation__tab"
                :class={`$store.schoolFoundation.activeTab === '${tab.key}' ? 'school-foundation__tab--active' : ''`}
                @click={`$store.schoolFoundation.activeTab = '${tab.key}'`}
              >
                {tab.label}
              </button>
            ))}
          </div>

          <template x-if="!$store.schoolFoundation.hasSchool">
            <div class="school-foundation__empty" x-text="$store.schoolFoundation.schoolRequiredMessage"></div>
          </template>

          <div class="school-foundation__tab-panel" x-show="$store.schoolFoundation.hasSchool && $store.schoolFoundation.activeTab === 'classes'" x-cloak>
            <div class="school-foundation__stack">
              <section class="school-foundation__section-card school-foundation__section-card--header">
                <div class="school-foundation__section-intro">
                  <div class="school-foundation__section-copy">
                    <h2 class="av-card-heading">Classes</h2>
                    <p class="av-text-soft">Create and manage class levels for this school.</p>
                  </div>
                  <AvButton type="button" @click.prevent="$store.schoolFoundation.openClassDrawer(); $store.appDrawer.open('class')">Add class</AvButton>
                </div>
              </section>

              <section class="school-foundation__section-card school-foundation__section-card--list">
                <div class="school-foundation__list">
                  <template x-if="$store.schoolFoundation.classes.length === 0">
                    <p class="av-text-soft">No classes yet.</p>
                  </template>
                  <template x-for="item in $store.schoolFoundation.classes" :key="item.id">
                    <article class="school-foundation__row">
                      <div class="school-foundation__row-title">
                        <strong x-text="item.name"></strong>
                        <div class="school-foundation__row-actions">
                          <button
                            type="button"
                            class="school-foundation__icon-button"
                            title="Edit class"
                            aria-label="Edit class"
                            @click.prevent="$store.schoolFoundation.openClassEditDrawer(item); $store.appDrawer.open('class')"
                          >
                            <AvIcon name="edit" size="sm" />
                          </button>
                          <button
                            type="button"
                            class="school-foundation__icon-button school-foundation__icon-button--danger"
                            title="Delete class"
                            aria-label="Delete class"
                            @click.prevent="$store.schoolFoundation.openDeleteConfirm('class', item.id, item.name)"
                          >
                            <AvIcon name="trash" size="sm" />
                          </button>
                        </div>
                      </div>
                      <span class="av-text-soft">Order <span x-text="item.sortOrder"></span></span>
                    </article>
                  </template>
                </div>
              </section>
            </div>
          </div>

          <div class="school-foundation__tab-panel" x-show="$store.schoolFoundation.hasSchool && $store.schoolFoundation.activeTab === 'sections'" x-cloak>
            <div class="school-foundation__stack">
              <section class="school-foundation__section-card school-foundation__section-card--header">
                <div class="school-foundation__section-intro">
                  <div class="school-foundation__section-copy">
                    <h2 class="av-card-heading">Sections</h2>
                    <p class="av-text-soft">Create and manage sections within each class.</p>
                  </div>
                  <AvButton type="button" @click.prevent="$store.schoolFoundation.openSectionDrawer(); $store.appDrawer.open('section')">Add section</AvButton>
                </div>
              </section>

              <section class="school-foundation__section-card school-foundation__section-card--list">
                <div class="school-foundation__list">
                  <template x-if="$store.schoolFoundation.sections.length === 0">
                    <p class="av-text-soft">No sections yet.</p>
                  </template>
                  <template x-for="item in $store.schoolFoundation.sections" :key="item.id">
                    <article class="school-foundation__row">
                      <div class="school-foundation__row-title">
                        <strong x-text="item.name"></strong>
                        <div class="school-foundation__row-actions">
                          <button
                            type="button"
                            class="school-foundation__icon-button"
                            title="Edit section"
                            aria-label="Edit section"
                            @click.prevent="$store.schoolFoundation.openSectionEditDrawer(item); $store.appDrawer.open('section')"
                          >
                            <AvIcon name="edit" size="sm" />
                          </button>
                          <button
                            type="button"
                            class="school-foundation__icon-button school-foundation__icon-button--danger"
                            title="Delete section"
                            aria-label="Delete section"
                            @click.prevent="$store.schoolFoundation.openDeleteConfirm('section', item.id, item.name)"
                          >
                            <AvIcon name="trash" size="sm" />
                          </button>
                        </div>
                      </div>
                      <span class="av-text-soft" x-text="$store.schoolFoundation.getClassName(item.classId)"></span>
                    </article>
                  </template>
                </div>
              </section>
            </div>
          </div>

          <div class="school-foundation__tab-panel" x-show="$store.schoolFoundation.hasSchool && $store.schoolFoundation.activeTab === 'subjects'" x-cloak>
            <div class="school-foundation__stack">
              <section class="school-foundation__section-card school-foundation__section-card--header">
                <div class="school-foundation__section-intro">
                  <div class="school-foundation__section-copy">
                    <h2 class="av-card-heading">Subjects</h2>
                    <p class="av-text-soft">Create and manage the subject catalog for this school.</p>
                  </div>
                  <AvButton type="button" @click.prevent="$store.schoolFoundation.openSubjectDrawer(); $store.appDrawer.open('subject')">Add subject</AvButton>
                </div>
              </section>

              <section class="school-foundation__section-card school-foundation__section-card--list">
                <div class="school-foundation__list">
                  <template x-if="$store.schoolFoundation.subjects.length === 0">
                    <p class="av-text-soft">No subjects yet.</p>
                  </template>
                  <template x-for="item in $store.schoolFoundation.subjects" :key="item.id">
                    <article class="school-foundation__row">
                      <div class="school-foundation__row-title">
                        <strong x-text="item.name"></strong>
                        <div class="school-foundation__row-actions">
                          <button
                            type="button"
                            class="school-foundation__icon-button"
                            title="Edit subject"
                            aria-label="Edit subject"
                            @click.prevent="$store.schoolFoundation.openSubjectEditDrawer(item); $store.appDrawer.open('subject')"
                          >
                            <AvIcon name="edit" size="sm" />
                          </button>
                          <button
                            type="button"
                            class="school-foundation__icon-button school-foundation__icon-button--danger"
                            title="Delete subject"
                            aria-label="Delete subject"
                            @click.prevent="$store.schoolFoundation.openDeleteConfirm('subject', item.id, item.name)"
                          >
                            <AvIcon name="trash" size="sm" />
                          </button>
                        </div>
                      </div>
                      <span class="av-text-soft" x-text="item.code || '-'"></span>
                    </article>
                  </template>
                </div>
              </section>
            </div>
          </div>

          <div class="school-foundation__tab-panel" x-show="$store.schoolFoundation.hasSchool && $store.schoolFoundation.activeTab === 'students'" x-cloak>
            <div class="school-foundation__stack">
              <section class="school-foundation__section-card school-foundation__section-card--header">
                <div class="school-foundation__section-intro">
                  <div class="school-foundation__section-copy">
                    <h2 class="av-card-heading">Students</h2>
                    <p class="av-text-soft">Create internal student records scoped to this school.</p>
                  </div>
                  <AvButton type="button" @click.prevent="$store.schoolFoundation.openStudentDrawer(); $store.appDrawer.open('student')">Add student</AvButton>
                </div>
              </section>

              <section class="school-foundation__section-card school-foundation__section-card--list">
                <div class="school-foundation__list">
                  <template x-if="$store.schoolFoundation.students.length === 0">
                    <p class="av-text-soft">No students yet.</p>
                  </template>
                  <template x-for="item in $store.schoolFoundation.students" :key="item.id">
                    <article class="school-foundation__row">
                      <div class="school-foundation__row-title">
                        <strong x-text="item.fullName"></strong>
                        <div class="school-foundation__row-actions">
                          <button
                            type="button"
                            class="school-foundation__icon-button"
                            title="Edit student"
                            aria-label="Edit student"
                            @click.prevent="$store.schoolFoundation.openStudentEditDrawer(item); $store.appDrawer.open('student')"
                          >
                            <AvIcon name="edit" size="sm" />
                          </button>
                          <button
                            type="button"
                            class="school-foundation__icon-button school-foundation__icon-button--danger"
                            title="Delete student"
                            aria-label="Delete student"
                            @click.prevent="$store.schoolFoundation.openDeleteConfirm('student', item.id, item.fullName)"
                          >
                            <AvIcon name="trash" size="sm" />
                          </button>
                        </div>
                      </div>
                      <span class="av-text-soft">
                        <span x-text="item.admissionNumber"></span>
                        ·
                        <span x-text="$store.schoolFoundation.getClassName(item.classId)"></span>
                        /
                        <span x-text="$store.schoolFoundation.getSectionName(item.sectionId)"></span>
                      </span>
                    </article>
                  </template>
                </div>
              </section>
            </div>
          </div>

          <div class="school-foundation__tab-panel" x-show="$store.schoolFoundation.hasSchool && $store.schoolFoundation.activeTab === 'teachers'" x-cloak>
            <div class="school-foundation__stack">
              <section class="school-foundation__section-card school-foundation__section-card--header">
                <div class="school-foundation__section-intro">
                  <div class="school-foundation__section-copy">
                    <h2 class="av-card-heading">Teachers</h2>
                    <p class="av-text-soft">Create internal teacher records for this school.</p>
                  </div>
                  <AvButton type="button" @click.prevent="$store.schoolFoundation.openTeacherDrawer(); $store.appDrawer.open('teacher')">Add teacher</AvButton>
                </div>
              </section>

              <section class="school-foundation__section-card school-foundation__section-card--list">
                <div class="school-foundation__list">
                  <template x-if="$store.schoolFoundation.teachers.length === 0">
                    <p class="av-text-soft">No teachers yet.</p>
                  </template>
                  <template x-for="item in $store.schoolFoundation.teachers" :key="item.id">
                    <article class="school-foundation__row">
                      <div class="school-foundation__row-title">
                        <strong x-text="item.fullName"></strong>
                        <div class="school-foundation__row-actions">
                          <button
                            type="button"
                            class="school-foundation__icon-button"
                            title="Edit teacher"
                            aria-label="Edit teacher"
                            @click.prevent="$store.schoolFoundation.openTeacherEditDrawer(item); $store.appDrawer.open('teacher')"
                          >
                            <AvIcon name="edit" size="sm" />
                          </button>
                          <button
                            type="button"
                            class="school-foundation__icon-button school-foundation__icon-button--danger"
                            title="Delete teacher"
                            aria-label="Delete teacher"
                            @click.prevent="$store.schoolFoundation.openDeleteConfirm('teacher', item.id, item.fullName)"
                          >
                            <AvIcon name="trash" size="sm" />
                          </button>
                        </div>
                      </div>
                      <span class="av-text-soft">
                        <span x-text="item.employeeNumber"></span>
                        ·
                        <span x-text="$store.schoolFoundation.getSubjectName(item.primarySubjectId)"></span>
                      </span>
                    </article>
                  </template>
                </div>
              </section>
            </div>
          </div>

          <div class="school-foundation__tab-panel" x-show="$store.schoolFoundation.hasSchool && $store.schoolFoundation.activeTab === 'attendance'" x-cloak>
            <div class="school-foundation__stack">
              <section class="school-foundation__section-card school-foundation__section-card--header">
                <div class="school-foundation__attendance-header">
                  <div class="school-foundation__section-copy">
                    <h2 class="av-card-heading">Daily Attendance</h2>
                    <p class="av-text-soft">
                      Mark daily student attendance. Present students are implied; only absences,
                      late arrivals, and excused cases are stored.
                    </p>
                  </div>

                  <div class="school-foundation__attendance-summary">
                    <div>
                      <span>Present</span>
                      <strong x-text="$store.schoolFoundation.attendanceSummary.present"></strong>
                    </div>
                    <div>
                      <span>Absent</span>
                      <strong x-text="$store.schoolFoundation.attendanceSummary.absent"></strong>
                    </div>
                    <div>
                      <span>Late</span>
                      <strong x-text="$store.schoolFoundation.attendanceSummary.late"></strong>
                    </div>
                    <div>
                      <span>Excused</span>
                      <strong x-text="$store.schoolFoundation.attendanceSummary.excused"></strong>
                    </div>
                  </div>
                </div>

                <div class="school-foundation__attendance-filters">
                  <label class="av-field">
                    <span class="av-field__label">Date</span>
                    <input
                      class="av-input"
                      type="date"
                      x-model="$store.schoolFoundation.attendanceDate"
                      @change="$store.schoolFoundation.setAttendanceDate($event.target.value)"
                    />
                  </label>

                  <label class="av-field">
                    <span class="av-field__label">Class</span>
                    <select
                      class="av-input"
                      x-model="$store.schoolFoundation.attendanceClassId"
                      x-effect="$nextTick(() => { $el.value = $store.schoolFoundation.attendanceClassId })"
                      @change="$store.schoolFoundation.setAttendanceClass($event.target.value)"
                    >
                      <option value="">Select class</option>
                      <template x-for="item in $store.schoolFoundation.classes" :key="item.id">
                        <option :value="String(item.id)" x-text="item.name"></option>
                      </template>
                    </select>
                  </label>

                  <label class="av-field">
                    <span class="av-field__label">Section</span>
                    <select
                      class="av-input"
                      x-model="$store.schoolFoundation.attendanceSectionId"
                      x-effect="$nextTick(() => { $el.value = $store.schoolFoundation.attendanceSectionId })"
                      @change="$store.schoolFoundation.setAttendanceSection($event.target.value)"
                    >
                      <option value="">Select section</option>
                      <template x-for="item in $store.schoolFoundation.attendanceSectionsForClass()" :key="item.id">
                        <option :value="String(item.id)" x-text="item.name"></option>
                      </template>
                    </select>
                  </label>

                  <AvButton
                    type="button"
                    :disabled="!$store.schoolFoundation.attendanceReady || $store.schoolFoundation.attendanceLoading"
                    @click.prevent="$store.schoolFoundation.loadDailyAttendance()"
                  >
                    <span x-text="$store.schoolFoundation.attendanceLoading ? 'Loading...' : 'Load'"></span>
                  </AvButton>
                </div>
              </section>

              <template x-if="$store.schoolFoundation.attendanceError">
                <div class="school-foundation__notice school-foundation__notice--error" x-text="$store.schoolFoundation.attendanceError"></div>
              </template>
              <template x-if="$store.schoolFoundation.attendanceSuccess">
                <div class="school-foundation__notice school-foundation__notice--success" x-text="$store.schoolFoundation.attendanceSuccess"></div>
              </template>

              <section class="school-foundation__section-card school-foundation__section-card--list">
                <div class="school-foundation__attendance-toolbar">
                  <div class="school-foundation__section-copy">
                    <h3 class="av-card-heading">Virtual classroom</h3>
                    <p class="av-text-soft">
                      <span x-text="$store.schoolFoundation.getClassName($store.schoolFoundation.attendanceClassId)"></span>
                      <span x-show="$store.schoolFoundation.attendanceSectionId"> / </span>
                      <span x-text="$store.schoolFoundation.getSectionName($store.schoolFoundation.attendanceSectionId)"></span>
                    </p>
                  </div>
                  <AvButton
                    type="button"
                    :disabled="!$store.schoolFoundation.attendanceLoaded || $store.schoolFoundation.attendanceStudents.length === 0 || $store.schoolFoundation.attendanceSaving"
                    @click.prevent="$store.schoolFoundation.saveDailyAttendance()"
                  >
                    <span x-text="$store.schoolFoundation.attendanceSaving ? 'Saving...' : 'Save attendance'"></span>
                  </AvButton>
                </div>

                <template x-if="$store.schoolFoundation.attendanceEmptyMessage">
                  <div class="school-foundation__empty" x-text="$store.schoolFoundation.attendanceEmptyMessage"></div>
                </template>

                <template x-if="$store.schoolFoundation.attendanceStudents.length > 0">
                  <div class="school-foundation__attendance-grid">
                    <template x-for="student in $store.schoolFoundation.attendanceStudents" :key="student.id">
                      <article
                        class="school-foundation__attendance-student"
                        :class="$store.schoolFoundation.attendanceStatusClass(student.attendanceStatus)"
                      >
                        <div class="school-foundation__row-title">
                          <div>
                            <strong x-text="student.fullName"></strong>
                            <p class="av-text-soft">
                              <span x-text="student.rollNumber || student.admissionNumber || '-'"></span>
                            </p>
                          </div>
                          <span class="school-foundation__attendance-badge" x-text="student.attendanceStatus"></span>
                        </div>

                        <div class="school-foundation__attendance-statuses" role="group" aria-label="Attendance status">
                          <button
                            type="button"
                            class="school-foundation__attendance-status"
                            :class="student.attendanceStatus === 'present' ? 'school-foundation__attendance-status--active' : ''"
                            @click.prevent="$store.schoolFoundation.setAttendanceStatus(student.id, 'present')"
                          >
                            Present
                          </button>
                          <button
                            type="button"
                            class="school-foundation__attendance-status"
                            :class="student.attendanceStatus === 'absent' ? 'school-foundation__attendance-status--active' : ''"
                            @click.prevent="$store.schoolFoundation.setAttendanceStatus(student.id, 'absent')"
                          >
                            Absent
                          </button>
                          <button
                            type="button"
                            class="school-foundation__attendance-status"
                            :class="student.attendanceStatus === 'late' ? 'school-foundation__attendance-status--active' : ''"
                            @click.prevent="$store.schoolFoundation.setAttendanceStatus(student.id, 'late')"
                          >
                            Late
                          </button>
                          <button
                            type="button"
                            class="school-foundation__attendance-status"
                            :class="student.attendanceStatus === 'excused' ? 'school-foundation__attendance-status--active' : ''"
                            @click.prevent="$store.schoolFoundation.setAttendanceStatus(student.id, 'excused')"
                          >
                            Excused
                          </button>
                        </div>
                      </article>
                    </template>
                  </div>
                </template>
              </section>

              <section class="school-foundation__section-card school-foundation__section-card--list">
                <div class="school-foundation__attendance-toolbar">
                  <div class="school-foundation__section-copy">
                    <h3 class="av-card-heading">Recent attendance</h3>
                    <p class="av-text-soft">Recent exception-only attendance sessions.</p>
                  </div>
                </div>

                <template x-if="$store.schoolFoundation.attendanceRecent.length === 0">
                  <p class="av-text-soft">No recent attendance sessions yet.</p>
                </template>

                <template x-if="$store.schoolFoundation.attendanceRecent.length > 0">
                  <div class="school-foundation__recent-attendance">
                    <template x-for="session in $store.schoolFoundation.attendanceRecent" :key="`${session.attendanceDate}-${session.classId}-${session.sectionId}`">
                      <article class="school-foundation__recent-attendance-row">
                        <div>
                          <strong x-text="session.attendanceDate"></strong>
                          <p class="av-text-soft">
                            <span x-text="session.className"></span>
                            /
                            <span x-text="session.sectionName"></span>
                          </p>
                        </div>
                        <span>
                          <span x-text="session.exceptionCount"></span>
                          exceptions
                        </span>
                      </article>
                    </template>
                  </div>
                </template>
              </section>
            </div>
          </div>
        </AvCard>

        <div x-on:av-confirm.window="if ($event.detail?.id === 'school-foundation-delete-dialog') $store.schoolFoundation.confirmDelete()">
          <AvConfirmDialog
            id="school-foundation-delete-dialog"
            headline="Delete foundation record?"
            description="Confirm before deleting this owner-scoped school record. This action cannot be undone."
            confirmLabel="Delete"
            cancelLabel="Cancel"
            variant="danger"
          />
        </div>
      </div>
    </AvContainer>
  </section>

  <style>
    .school-foundation__header,
    .school-foundation__card-grid,
    .school-foundation__stack {
      display: grid;
      gap: 1.25rem;
    }

    .school-foundation__header {
      align-items: end;
      grid-template-columns: minmax(0, 1fr);
    }

    .school-foundation__card-grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .school-foundation__form-grid {
      display: grid;
      gap: 0.85rem;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }

    .school-foundation__summary-grid {
      display: grid;
      gap: 0.65rem;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    }

    .school-foundation__summary-item {
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 8px;
      display: grid;
      gap: 0.2rem;
      padding: 0.75rem;
    }

    .school-foundation__summary-item span {
      color: rgba(203, 213, 225, 0.68);
      font-size: 0.78rem;
    }

    .school-foundation__summary-item strong {
      color: rgba(248, 250, 252, 0.96);
      font-size: 0.95rem;
      overflow-wrap: anywhere;
    }

    .school-foundation__notice,
    .school-foundation__empty {
      border: 1px solid rgba(148, 163, 184, 0.18);
      border-radius: 8px;
      padding: 0.85rem 1rem;
    }

    .school-foundation__notice--error {
      border-color: rgba(248, 113, 113, 0.35);
      color: rgb(254, 202, 202);
    }

    .school-foundation__notice--success {
      border-color: rgba(74, 222, 128, 0.35);
      color: rgb(187, 247, 208);
    }

    .school-foundation__drawer-error {
      color: rgb(254, 202, 202);
      margin: 0;
    }

    .school-foundation__workspace {
      padding: 1rem;
    }

    .school-foundation__tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }

    .school-foundation__tab {
      border: 1px solid rgba(148, 163, 184, 0.18);
      border-radius: 8px;
      color: rgba(226, 232, 240, 0.78);
      padding: 0.5rem 0.75rem;
    }

    .school-foundation__tab--active {
      background: rgba(34, 197, 94, 0.12);
      border-color: rgba(34, 197, 94, 0.35);
      color: rgba(240, 253, 244, 0.98);
    }

    .school-foundation__tab-panel {
      margin-top: 0.75rem;
    }

    .school-foundation__section-card {
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 8px;
      padding: 0.85rem;
    }

    .school-foundation__section-intro {
      align-content: start;
      align-items: start;
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
      justify-content: space-between;
    }

    .school-foundation__section-copy {
      display: grid;
      gap: 0.35rem;
    }

    .school-foundation__section-copy :global(.av-card-heading),
    .school-foundation__section-copy :global(.av-text-soft) {
      margin: 0;
    }

    .school-foundation__list {
      display: grid;
      gap: 0.65rem;
      grid-template-columns: 1fr;
    }

    .school-foundation__row {
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 8px;
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
      padding: 0.75rem;
    }

    .school-foundation__row-title {
      align-items: start;
      display: flex;
      gap: 0.75rem;
      justify-content: space-between;
      min-width: 0;
    }

    .school-foundation__row-title strong {
      min-width: 0;
      overflow-wrap: anywhere;
    }

    .school-foundation__row-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      justify-content: flex-end;
      margin-left: auto;
    }

    .school-foundation__icon-button {
      align-items: center;
      background: rgba(15, 23, 42, 0.48);
      border: 1px solid rgba(148, 163, 184, 0.22);
      border-radius: 8px;
      color: rgba(226, 232, 240, 0.86);
      display: inline-flex;
      height: 2rem;
      justify-content: center;
      padding: 0;
      transition:
        background-color 150ms ease,
        border-color 150ms ease,
        color 150ms ease;
      width: 2rem;
    }

    .school-foundation__icon-button:hover,
    .school-foundation__icon-button:focus-visible {
      background: rgba(34, 197, 94, 0.12);
      border-color: rgba(34, 197, 94, 0.35);
      color: rgba(240, 253, 244, 0.98);
    }

    .school-foundation__icon-button--danger:hover,
    .school-foundation__icon-button--danger:focus-visible {
      background: rgba(248, 113, 113, 0.12);
      border-color: rgba(248, 113, 113, 0.35);
      color: rgb(254, 202, 202);
    }

    .school-foundation__attendance-header,
    .school-foundation__attendance-toolbar {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      justify-content: space-between;
    }

    .school-foundation__attendance-summary,
    .school-foundation__attendance-filters {
      display: grid;
      gap: 0.65rem;
      grid-template-columns: 1fr;
    }

    .school-foundation__attendance-summary div {
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 8px;
      min-width: 6rem;
      padding: 0.65rem 0.75rem;
    }

    .school-foundation__attendance-summary span {
      color: rgba(203, 213, 225, 0.68);
      display: block;
      font-size: 0.74rem;
      margin-bottom: 0.15rem;
    }

    .school-foundation__attendance-summary strong {
      color: rgba(248, 250, 252, 0.96);
      font-size: 1.05rem;
    }

    .school-foundation__attendance-filters {
      align-items: end;
      margin-top: 1rem;
    }

    .school-foundation__attendance-grid {
      display: grid;
      gap: 0.75rem;
      grid-template-columns: 1fr;
      margin-top: 1rem;
    }

    .school-foundation__attendance-student {
      background: rgba(15, 23, 42, 0.3);
      border: 1px solid rgba(34, 197, 94, 0.22);
      border-radius: 8px;
      display: grid;
      gap: 0.85rem;
      padding: 0.85rem;
    }

    .school-foundation__attendance-student--absent {
      border-color: rgba(248, 113, 113, 0.36);
    }

    .school-foundation__attendance-student--late {
      border-color: rgba(251, 191, 36, 0.36);
    }

    .school-foundation__attendance-student--excused {
      border-color: rgba(96, 165, 250, 0.36);
    }

    .school-foundation__attendance-badge {
      border: 1px solid rgba(148, 163, 184, 0.18);
      border-radius: 999px;
      color: rgba(226, 232, 240, 0.78);
      font-size: 0.72rem;
      padding: 0.18rem 0.5rem;
      text-transform: capitalize;
    }

    .school-foundation__attendance-statuses {
      display: grid;
      gap: 0.45rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .school-foundation__attendance-status {
      border: 1px solid rgba(148, 163, 184, 0.18);
      border-radius: 8px;
      color: rgba(226, 232, 240, 0.78);
      font-size: 0.78rem;
      padding: 0.45rem 0.35rem;
      text-align: center;
    }

    .school-foundation__attendance-status--active {
      background: rgba(34, 197, 94, 0.12);
      border-color: rgba(34, 197, 94, 0.35);
      color: rgba(240, 253, 244, 0.98);
    }

    .school-foundation__recent-attendance {
      display: grid;
      gap: 0.6rem;
    }

    .school-foundation__recent-attendance-row {
      align-items: center;
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 8px;
      display: flex;
      gap: 1rem;
      justify-content: space-between;
      padding: 0.75rem;
    }

    .school-foundation__recent-attendance-row > span {
      color: rgba(226, 232, 240, 0.78);
      font-size: 0.84rem;
      white-space: nowrap;
    }

    @media (min-width: 900px) {
      .school-foundation__header,
      .school-foundation__card-grid {
        grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
      }

      .school-foundation__section-intro {
        align-items: center;
        flex-direction: row;
      }

      .school-foundation__list {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .school-foundation__attendance-header,
      .school-foundation__attendance-toolbar {
        align-items: start;
        flex-direction: row;
      }

      .school-foundation__attendance-summary {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }

      .school-foundation__attendance-filters {
        grid-template-columns: 1fr 1fr 1fr auto;
      }

      .school-foundation__attendance-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
  </style>
</AppShell>
